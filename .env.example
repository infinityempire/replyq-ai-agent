# ReplyQ AI Agent - Environment Configuration Example
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME="ReplyQ AI Agent"
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# AI Providers (at least one required)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
DEFAULT_AI_PROVIDER=openai
AI_MODEL=gpt-4-turbo-preview

# Whisper (Voice Transcription)
WHISPER_MODEL=base

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Database
DATABASE_URL=sqlite+aiosqlite:///./replyq.db
DATABASE_ECHO=false

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Payment Gateway (Stripe)
STRIPE_API_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Human Escalation
HUMAN_ESCALATION_WEBHOOK_URL=https://your-webhook-url.com/escalate
BLACKOUT_MODE_THRESHOLD=3
BLACKOUT_MODE_ESCALATION_ENABLED=true

# Lead Scoring
INITIAL_LEAD_SCORE=50
MAX_LEAD_SCORE=100
MIN_LEAD_SCORE=0

# Security
SECRET_KEY=change-this-to-a-secure-random-string
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_ENABLED=true
