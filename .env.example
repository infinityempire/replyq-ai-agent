# =============================================================================
# Telegram Voice Bot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to version control!

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

APP_NAME="Telegram Voice Bot"
APP_VERSION="1.0.0"
DEBUG=false

# =============================================================================
# TELEGRAM CONFIGURATION
# =============================================================================
# Get your bot token from @BotFather on Telegram
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: MTProto API credentials (for advanced features)
# TELEGRAM_API_ID=12345
# TELEGRAM_API_HASH=your_api_hash_here

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================
# For production: Set the full URL where Telegram should send updates
# This MUST be a publicly accessible HTTPS URL
# Example: https://yourdomain.com/webhook
# For Termux/local development, leave empty to use polling mode

TELEGRAM_WEBHOOK_URL=

# =============================================================================
# GOOGLE AI STUDIO CONFIGURATION
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This is used for voice message transcription via Gemini models

GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Model selection (gemini-1.5-flash recommended for transcription)
GOOGLE_AI_MODEL=gemini-1.5-flash

# =============================================================================
# PAYPAL CONFIGURATION (Optional - for future payment features)
# =============================================================================
# Get credentials from: https://developer.paypal.com/

# Sandbox mode
PAYPAL_CLIENT_ID=your_paypal_client_id_sandbox
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_sandbox
PAYPAL_MODE=sandbox

# Production mode (uncomment when ready)
# PAYPAL_CLIENT_ID=your_paypal_client_id_live
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_live
# PAYPAL_MODE=live

# Webhook ID (from PayPal app settings)
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# =============================================================================
# DATABASE CONFIGURATION (Optional - for future persistence)
# =============================================================================

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/voicebot

# SQLite example:
# DATABASE_URL=sqlite:///./voicebot.db

# =============================================================================
# REDIS CACHE (Optional - for caching and session management)
# =============================================================================

# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HOST=0.0.0.0
# PORT=8000